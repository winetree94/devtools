{
  "name": "devtools",
  "version": "0.1.0",
  "private": true,
  "description": "A personal CLI tool for web search, page extraction, and development-agent workflows.",
  "type": "module",
  "license": "MIT",
  "author": "winetree94",
  "repository": {
    "type": "git",
    "url": "https://git.winetree94.com/winetree94/devtools.git"
  },
  "keywords": [
    "cli",
    "web-search",
    "web-scraping",
    "agent",
    "devtools"
  ],
  "imports": {
    "#app/*": "./src/*"
  },
  "bin": {
    "devtools": "./src/index.ts"
  },
  "oclif": {
    "bin": "devtools",
    "dirname": "devtools",
    "commands": {
      "strategy": "explicit",
      "target": "./src/cli/commands/index.ts",
      "identifier": "COMMANDS"
    },
    "topicSeparator": " ",
    "plugins": [
      "@oclif/plugin-autocomplete"
    ],
    "topics": {
      "install": {
        "description": "Install packaged resources"
      },
      "uninstall": {
        "description": "Uninstall packaged resources"
      },
      "web": {
        "description": "Web utilities"
      }
    },
    "additionalHelpFlags": [
      "-h"
    ]
  },
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "node --watch src/index.ts",
    "start": "node src/index.ts",
    "typecheck": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "check": "npm run typecheck && biome check . && npm run test",
    "check:fix": "biome check --write .",
    "format": "biome format --write ."
  },
  "dependencies": {
    "@mozilla/readability": "^0.6.0",
    "@oclif/core": "^4.9.0",
    "@oclif/plugin-autocomplete": "^3.2.41",
    "dotenv": "^17.3.1",
    "jsdom": "^29.0.0",
    "turndown": "^7.2.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "@types/jsdom": "^28.0.0",
    "@types/node": "^25.5.0",
    "@types/turndown": "^5.0.6",
    "@vitest/coverage-v8": "^4.1.0",
    "execa": "^9.6.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
