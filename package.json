{
  "name": "devtools",
  "version": "0.1.0",
  "private": true,
  "description": "devtools CLI scaffolded with Node.js, TypeScript, and Biome.",
  "type": "module",
  "imports": {
    "#app/*": "./src/*"
  },
  "bin": {
    "devtools": "./src/index.ts"
  },
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "node --watch src/index.ts",
    "start": "node src/index.ts",
    "typecheck": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "check": "npm run typecheck && biome check . && npm run test",
    "check:fix": "biome check --write .",
    "format": "biome format --write ."
  },
  "dependencies": {
    "@mozilla/readability": "^0.6.0",
    "commander": "^14.0.1",
    "dotenv": "^16.6.1",
    "jsdom": "^27.0.0",
    "turndown": "^7.2.1",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "@vitest/coverage-v8": "^3.2.4",
    "@types/jsdom": "^27.0.0",
    "@types/node": "^24.5.2",
    "@types/turndown": "^5.0.5",
    "execa": "^9.6.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
